<h1>Tickets</h1>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Guest</th>
      <th>Department</th>
      <th>Status</th>
      <th>Priority</th>
      <th>Assigned Staff</th>
    </tr>
  </thead>
  <tbody>
    <% @tickets.each do |ticket| %>
      <tr>
        <td><%= ticket.id %></td>
        <td><%= ticket.guest.name %></td>
        <td><%= ticket.department.name %></td>
        <td><%= ticket.status %></td>
        <td><%= ticket.priority %></td>
        <td><%= ticket.staff&.name || "-" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
